{
  "name": "@gotsaeng/core",
  "version": "0.10.5",
  "description": "Core context compiler for GotSaeng OS.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wonkwonlee/gotsaeng-os.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/wonkwonlee/gotsaeng-os/issues"
  },
  "homepage": "https://github.com/wonkwonlee/gotsaeng-os/tree/main/packages/core#readme",
  "keywords": [
    "context-engineering",
    "markdown",
    "local-first",
    "llm",
    "context-compiler"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  }
}
